import javax.swing.*;
import javax.swing.border.MatteBorder;
import java.awt.*;
import java.awt.event.FocusAdapter;
import java.awt.event.FocusEvent;
import java.awt.geom.GeneralPath;

public class LoginPage extends JFrame {

    // Declare these at the class level so we can access them when the login button is clicked later
    private JTextField txtUsername;
    private JPasswordField txtPassword;
    private JButton btnSignIn;

    public LoginPage() {
        // Your foundation
        setTitle("Login Page");
        setSize(1100, 700);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setLocationRelativeTo(null); // Center on screen

        // 1. Setup the Wave Background Panel
        WavePanel mainPanel = new WavePanel();
        mainPanel.setLayout(new GridBagLayout()); // GridBag is great for centering a panel inside a larger window
        setContentPane(mainPanel); // This replaces your standard BorderLayout content pane

        // 2. Setup the Form Panel
        JPanel formPanel = new JPanel();
        formPanel.setOpaque(false); // Make it transparent so the background color/waves show through
        formPanel.setLayout(new BoxLayout(formPanel, BoxLayout.Y_AXIS));

        // 3. Add Logo / Title
        JLabel lblLogo = new JLabel("🚗 APU - ASC");
        lblLogo.setFont(new Font("SansSerif", Font.BOLD, 28));
        lblLogo.setForeground(new Color(100, 100, 255));
        lblLogo.setAlignmentX(Component.CENTER_ALIGNMENT);

        // 4. Initialize Username Field
        txtUsername = createCustomTextField("User Name");

        // 5. Initialize Password Field
        txtPassword = new JPasswordField("Password");
        txtPassword.setEchoChar((char) 0); // Show plain text initially for the placeholder
        styleTextField(txtPassword);

        // Password focus listener to handle the hiding/showing of dots
        txtPassword.addFocusListener(new FocusAdapter() {
            @Override
            public void focusGained(FocusEvent e) {
                if (String.valueOf(txtPassword.getPassword()).equals("Password")) {
                    txtPassword.setText("");
                    txtPassword.setEchoChar('•'); // Mask the password
                    txtPassword.setForeground(Color.BLACK);
                }
            }
            @Override
            public void focusLost(FocusEvent e) {
                if (String.valueOf(txtPassword.getPassword()).isEmpty()) {
                    txtPassword.setEchoChar((char) 0); // Unmask for placeholder
                    txtPassword.setText("Password");
                    txtPassword.setForeground(Color.GRAY);
                }
            }
        });

        // 6. Initialize Sign In Button
        btnSignIn = new JButton("Sign In");
        btnSignIn.setAlignmentX(Component.CENTER_ALIGNMENT);
        btnSignIn.setMaximumSize(new Dimension(300, 45)); // Slightly larger button for your 1100x700 frame
        btnSignIn.setPreferredSize(new Dimension(300, 45));
        btnSignIn.setBackground(new Color(128, 128, 255));
        btnSignIn.setForeground(Color.WHITE);
        btnSignIn.setFont(new Font("SansSerif", Font.BOLD, 16));
        btnSignIn.setFocusPainted(false);
        btnSignIn.setBorderPainted(false);
        btnSignIn.setCursor(new Cursor(Cursor.HAND_CURSOR));

        // 7. Assemble the components with spacing
        formPanel.add(lblLogo);
        formPanel.add(Box.createVerticalStrut(50));
        formPanel.add(txtUsername);
        formPanel.add(Box.createVerticalStrut(25));
        formPanel.add(txtPassword);
        formPanel.add(Box.createVerticalStrut(40));
        formPanel.add(btnSignIn);

        // Add the finished form to the center of the main panel
        mainPanel.add(formPanel);
    }

    // --- HELPER METHODS FOR STYLING ---

    private JTextField createCustomTextField(String placeholder) {
        JTextField textField = new JTextField(placeholder);
        styleTextField(textField);

        textField.addFocusListener(new FocusAdapter() {
            @Override
            public void focusGained(FocusEvent e) {
                if (textField.getText().equals(placeholder)) {
                    textField.setText("");
                    textField.setForeground(Color.BLACK);
                }
            }
            @Override
            public void focusLost(FocusEvent e) {
                if (textField.getText().isEmpty()) {
                    textField.setText(placeholder);
                    textField.setForeground(Color.GRAY);
                }
            }
        });
        return textField;
    }

    private void styleTextField(JTextField textField) {
        textField.setMaximumSize(new Dimension(300, 35));
        textField.setPreferredSize(new Dimension(300, 35));
        textField.setFont(new Font("SansSerif", Font.PLAIN, 16));
        textField.setForeground(Color.GRAY);
        textField.setOpaque(false);
        textField.setCaretColor(new Color(128, 128, 255));
        // Draw only the bottom border line
        textField.setBorder(new MatteBorder(0, 0, 1, 0, Color.LIGHT_GRAY));
    }

    // --- INNER CLASS FOR CUSTOM BACKGROUND WAVES ---

    class WavePanel extends JPanel {
        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2d = (Graphics2D) g;
            g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);

            int width = getWidth();
            int height = getHeight();

            // Background Color
            g2d.setColor(new Color(248, 248, 250));
            g2d.fillRect(0, 0, width, height);

            // Back Wave (Lighter)
            g2d.setColor(new Color(200, 200, 255, 150));
            GeneralPath wave1 = new GeneralPath();
            wave1.moveTo(0, height * 0.85);
            wave1.quadTo(width * 0.25, height * 0.75, width * 0.5, height * 0.85);
            wave1.quadTo(width * 0.75, height * 0.95, width, height * 0.85);
            wave1.lineTo(width, height);
            wave1.lineTo(0, height);
            wave1.closePath();
            g2d.fill(wave1);

            // Front Wave (Darker)
            g2d.setColor(new Color(150, 150, 255, 180));
            GeneralPath wave2 = new GeneralPath();
            wave2.moveTo(0, height * 0.90);
            wave2.quadTo(width * 0.30, height * 0.80, width * 0.60, height * 0.92);
            wave2.quadTo(width * 0.85, height * 0.98, width, height * 0.88);
            wave2.lineTo(width, height);
            wave2.lineTo(0, height);
            wave2.closePath();
            g2d.fill(wave2);
        }
    }

    // Your main method
    public static void main(String[] args){
        // Good practice to wrap the execution in invokeLater for Thread Safety in Swing
        SwingUtilities.invokeLater(() -> {
            new LoginPage().setVisible(true);
        });
    }
}

